
  <ThingDef ParentName="ApparelArmorPowerBase">
    <defName>Apparel_ArmorMarineGrenadier</defName>
    <label>grenadier armor</label>
    <description>A variant of marine armor with an integrated frag launcher on the shoulder. The armor is slightly less protective than standard marine armor. The launcher can only hold a limited amount of ammo and must be reloaded after use.\n\nGrenadiers usually specialize in breaching buildings or internal ship bulkheads. While not effective at very long range, grenadiers can be surprisingly deadly in confined quarters.</description>
    <costList>
      <Steel>75</Steel>
      <ComponentIndustrial>4</ComponentIndustrial>
    </costList>
    <statBases>
      <ArmorRating_Sharp>1.01</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.40</ArmorRating_Blunt>
      <ArmorRating_Heat>0.49</ArmorRating_Heat>
    </statBases>
    <graphicData>
      <texPath>Things/Pawn/Humanlike/Apparel/GrenadierArmor/GrenadierArmor</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <apparel>
      <scoreOffset>4</scoreOffset>
      <wornGraphicPath>Things/Pawn/Humanlike/Apparel/GrenadierArmor/GrenadierArmor</wornGraphicPath>
      <abilities>
        <li>LaunchFragGrenadeGrenadierArmor</li>
      </abilities>
    </apparel>
    <comps>
      <li Class="CompProperties_ApparelReloadable">
        <maxCharges>2</maxCharges>
        <ammoDef>Steel</ammoDef>
        <ammoCountPerCharge>25</ammoCountPerCharge>
        <baseReloadTicks>60</baseReloadTicks>
        <soundReload>Standard_Reload</soundReload>
        <hotKey>Misc4</hotKey>
        <chargeNoun>grenade</chargeNoun>
        <displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
      </li>
    </comps>
    <recipeMaker>
      <displayPriority>130</displayPriority>
    </recipeMaker>
  </ThingDef>
  <ThingDef ParentName="BaseFragGrenadeProjectile">
    <defName>Proj_GrenadierGrenade</defName>
    <label>frag grenade</label>
    <projectile>
      <speed>16</speed>
    </projectile>
  </ThingDef>


  <AbilityDef>
    <defName>LaunchFragGrenadeGrenadierArmor</defName>
    <label>launch frag grenade</label>
    <description>Launch a grenade. Can be reloaded using steel.</description>
    <iconPath>UI/Commands/LaunchFragGrenade</iconPath>
    <gizmoClass>AiUseableApparel.Command_AbilityApparel</gizmoClass>
    <aiCanUse>true</aiCanUse>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>12.9</range>
      <warmupTime>1.5</warmupTime>
      <soundCast>Shot_IncendiaryLauncher</soundCast>
      <ai_IsBuildingDestroyer>true</ai_IsBuildingDestroyer>
      <targetParams>
        <canTargetLocations>true</canTargetLocations>
      </targetParams>
      <rangedFireRulepack>Combat_RangedFire_Thrown</rangedFireRulepack>
    </verbProperties>
    <comps>
      <li Class="CompProperties_AbilityLaunchProjectile">
        <projectileDef>Proj_GrenadeFrag</projectileDef>
      </li>
      <li Class="AiUseableApparel.CompProperties_AbilityChargesApparel">
      </li>
    </comps>
  </AbilityDef>