<?xml version="1.0" encoding="utf-8" ?>
<Patch>
    <!-- Needs royalty -->
    <Operation Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorMarineGrenadier"]/apparel/abilities</xpath>
        <nomatch Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorMarineGrenadier"]/apparel</xpath>
            <value>
                <abilities /> 
            </value>
        </nomatch>
    </Operation>    
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorMarineGrenadier"]/apparel/abilities</xpath>
        <value>
            <li>LaunchFragGrenadeGrenadierArmor</li>
        </value>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <xpath>Defs/ThingDef[defName="Apparel_ArmorMarineGrenadier"]/verbs</xpath>
    </Operation>
    <!-- Needs Anomaly -->
    <Operation Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[defName="Apparel_PackTurret"]/apparel/abilities</xpath>
        <nomatch Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_PackTurret"]/apparel</xpath>
            <value>
                <abilities /> 
            </value>
        </nomatch>
    </Operation>    
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_PackTurret"]/apparel/abilities</xpath>
        <value>
            <li>DeployTurret</li>
        </value>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <xpath>Defs/ThingDef[defName="Apparel_PackTurret"]/verbs</xpath>
    </Operation>
    <!-- Needs Ideology? -->
    <Operation Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[defName="Apparel_PackJump"]/apparel/abilities</xpath>
        <nomatch Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_PackJump"]/apparel</xpath>
            <value>
                <abilities /> 
            </value>
        </nomatch>
    </Operation>    
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Apparel_PackJump"]/apparel/abilities</xpath>
        <value>
            <li>JetJump</li>
        </value>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <xpath>Defs/ThingDef[defName="Apparel_PackJump"]/verbs</xpath>
    </Operation>
    <!-- Needs Ideology? -->   
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThinkTreeDef[defName="Humanlike"]/thinkRoot/subNodes</xpath>
        <value>
            <li Class="ThinkNode_Subtree">
                <treeDef>Abilities_AggressiveJump</treeDef>
            </li>
        </value>
    </Operation>
</Patch>